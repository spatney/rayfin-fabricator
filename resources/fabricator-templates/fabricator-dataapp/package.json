{
  "name": "fabricator-dataapp",
  "license": "MIT",
  "author": "Microsoft",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "template": {
    "name": "fabricator-dataapp",
    "displayName": "Data App",
    "description": "Fabric Analytics app — connect a Power BI semantic model and build interactive dashboards with DAX-powered visuals, then deploy to Fabric to try it."
  },
  "scripts": {
    "prebuild": "rayfin env --framework vite",
    "build": "npx fabric-app-data generate -o src/fabric.generated.ts && tsc -b --noCheck && vite build",
    "build:fabric": "npx fabric-app-data generate -o src/fabric.generated.ts && tsc -b --noCheck && vite build",
    "lint": "eslint .",
    "gallery": "vite",
    "preview": "node scripts/preview-visual.mjs",
    "rayfin:up": "rayfin up"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
