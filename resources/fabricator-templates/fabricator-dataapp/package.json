    "@microsoft/rayfin-data": "^1.33.1",
    "@microsoft/rayfin-lib": "^1.33.1",
    "@tailwindcss/vite": "^4.3.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "graphein": "^0.14.0",
