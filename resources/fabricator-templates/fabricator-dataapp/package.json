    "@graphein/node": "^0.14.0",
    "@microsoft/fabric-app-data-cli": "1.1.0",
    "@microsoft/fabric-app-data-cli-proxy": "1.0.0",
    "@microsoft/rayfin-cli": "^1.33.1",
    "@microsoft/rayfin-mcp": "^1.33.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
